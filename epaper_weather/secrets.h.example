#pragma once

// Copy to secrets.h and fill in your values. secrets.h is gitignored.

#define WIFI_SSID      "your_wifi_ssid"
#define WIFI_PASSWORD  "your_wifi_password"

#define HA_HOST        "homeassistant.local"
#define HA_PORT        8123
#define HA_TOKEN       "your_long_lived_access_token"
#define HA_ENTITY_ID   "weather.your_entity_id"

#define LOCATION_NAME  "Home"

#define MQTT_HOST  "homeassistant.local"
#define MQTT_PORT  1883
#define MQTT_USER  "your_mqtt_username"
#define MQTT_PASS  "your_mqtt_password"

// Sub-station boxes (center panel, lower half).
// Each station needs a display label (max 15 chars) and the MQTT state topic
// that publishes JSON with "temperature" (°C) and "humidity" (%) keys.
// The source device must publish retained messages so the broker holds the
// last value between wake cycles.
#define STATION_0_LABEL  "Indoors"
#define STATION_0_TOPIC  "home/air_xxxxxx/state"
#define STATION_1_LABEL  "Outdoors"
#define STATION_1_TOPIC  "home/air_yyyyyy/state"
